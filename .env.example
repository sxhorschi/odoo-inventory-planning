# Inventory Overview – Environment Variables

# Dashboard login credentials
ADMIN_USER=admin
ADMIN_PASSWORD=changeme

# Flask secret key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=

# Odoo connection (or configure via Settings page)
ODOO_URL=https://your-instance.odoo.com
ODOO_DB=your-database
ODOO_USER=
ODOO_PASSWORD=

# Production mode (use waitress instead of Flask dev server)
PRODUCTION=0
PORT=5002

# Optional: URL prefix for reverse proxy
# URL_PREFIX=/inventory
